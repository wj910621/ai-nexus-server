{
  "name": "trigen-desktop",
  "version": "1.0.0",
  "description": "Y·NEX Desktop — One Input. Anything. 135+ AI 模型 · 全能 AI 桌面端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.trigen.desktop",
    "productName": "Y·NEX Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icons/"
    ],
    "extraResources": [
      {
        "from": "icons/",
        "to": "icons/"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icons/icon.png",
      "artifactName": "Y·NEX-Desktop-${version}-win-Setup.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "icons/icon.png",
      "artifactName": "Y·NEX-Desktop-${version}-mac.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icons/",
      "artifactName": "Y·NEX-Desktop-${version}-linux.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Y·NEX Desktop",
      "installerIcon": "icons/icon.png",
      "uninstallDisplayName": "Y·NEX Desktop"
    }
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  }
}
