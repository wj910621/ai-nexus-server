# ============================================
# AI Nexus 大模型聚合平台 - API 密钥配置
# 复制此文件为 .env 并填入你的密钥
# ============================================

# 服务端口
PORT=3001

# ---- OpenAI (https://platform.openai.com/api-keys) ----
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- DeepSeek (https://platform.deepseek.com/api_keys) ----
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ---- Google Gemini (https://aistudio.google.com/apikey) ----
GEMINI_API_KEY=your-gemini-key-here

# ---- 阿里云通义千问 (https://dashscope.console.aliyun.com/apiKey) ----
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# ---- 月之暗面 Kimi (https://platform.moonshot.cn/console/api-keys) ----
MOONSHOT_API_KEY=sk-your-moonshot-key-here

# ---- 智谱 GLM (https://open.bigmodel.cn/usercenter/apikeys) ----
ZHIPU_API_KEY=your-zhipu-key-here

# ---- 零一万物 Yi (https://platform.lingyiwanwu.com/apikey) ----
YI_API_KEY=your-yi-key-here
