# ============================================
# TriGen AI 大模型聚合平台 - API 密钥配置
# 复制此文件为 .env 并填入你的密钥
# ============================================

# 服务端口
PORT=3001

# ---- JWT 密钥（生产环境必须修改，至少 32 位随机字符串） ----
JWT_SECRET=your-very-long-random-secret-key-at-least-32-chars

# ---- 管理员密码（生产环境必须修改） ----
ADMIN_PASSWORD=your-strong-admin-password

# ---- 允许的跨域来源（多个用逗号分隔；留空则只允许同域） ----
# ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# ---- DeepSeek ----
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ---- 阿里百炼 DashScope ----
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# ---- Kimi 月之暗面 ----
MOONSHOT_API_KEY=sk-your-moonshot-key-here

# ---- 智谱 GLM ----
ZHIPU_API_KEY=your-zhipu-key-here

# ---- 硅基流动 SiliconFlow ----
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here

# ---- DMXAPI ----
OPENAI_BASE_URL=https://www.dmxapi.cn/v1
OPENAI_API_KEY=sk-your-dmxapi-key-here
DMXAPI_API_KEY=sk-your-dmxapi-key-here

# ---- OpenRouter ----
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# ---- 七牛云 ----
QINIU_API_KEY=your-qiniu-key-here

# ---- 腾讯混元 ----
HUNYUAN_API_KEY=sk-your-hunyuan-key-here

# ---- 腾讯云 TokenHub ----
TOKENHUB_API_KEY=sk-your-tokenhub-key-here

# ---- Agnes ----
AGNES_API_KEY=sk-your-agnes-key-here

# ---- Meshy 3D ----
MESHY_API_KEY=msy-your-meshy-key-here

# ---- 百度千帆 ----
QIANFAN_AK=your-qianfan-ak-here
QIANFAN_SK=your-qianfan-sk-here

# ---- 火山引擎 Ark ----
ARK_API_KEY=ark-your-ark-key-here

# ---- 百川智能 ----
BAICHUAN_API_KEY=sk-your-baichuan-key-here

# ---- Suno 音乐 ----
SUNO_API_KEY=your-suno-key-here
SUNO_API_BASE=https://open.suno.cn/api/v1

# ---- API Nexus ----
NEXUS_API_KEY=sk-your-nexus-key-here
NEXUS_API_BASE=https://apinexus.net/v1

# ---- 可灵 Kling ----
KLING_AK=your-kling-ak-here
KLING_SK=your-kling-sk-here

# ---- Tripo3D ----
TRIPO3D_API_KEY=tcli-your-tripo3d-key-here

# ---- Mureka ----
MUREKA_API_KEY=op-your-mureka-key-here

# ---- OpenCode.ai ----
OPENCODE_API_KEY=sk-your-opencode-key-here

# ---- Google Gemini ----
GEMINI_API_KEY=your-gemini-key-here
